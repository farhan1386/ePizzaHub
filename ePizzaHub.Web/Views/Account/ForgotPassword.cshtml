@{
    ViewData["Title"] = "Account Recovery Gate";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="bg-dark p-4 text-center text-white">
                    <span class="fs-1 d-block mb-1">🔑</span>
                    <h3 class="fw-black m-0">Reset Your Password</h3>
                    <p class="text-white-50 small m-0 mt-1">We will compile an authorization unlock code link token</p>
                </div>
                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-controller="Account" asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()

                        <div class="alert alert-info border-0 rounded-4 small p-3 mb-4 text-muted">
                            <i class="bi bi-info-circle-fill text-info me-2 fs-5 align-middle"></i> Enter your registered email below, and our server node will securely dispatch reset metadata instructions.
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark small text-uppercase tracking-wider">Account Email Address</label>
                            <div class="input-group border rounded-pill overflow-hidden bg-light shadow-sm">
                                <span class="input-group-text bg-transparent border-0 text-muted ps-3"><i class="bi bi-envelope-check"></i></span>
                                <input type="email" name="email" class="form-control bg-transparent border-0 py-2.5" placeholder="name@domain.com" required />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-danger w-100 rounded-pill py-2.5 fw-bold shadow-sm mb-3">
                            <i class="bi bi-send-check-fill me-2"></i>Send Recovery Link
                        </button>

                        <a asp-action="Login" class="btn btn-link w-100 text-decoration-none text-muted small fw-medium text-center">
                            <i class="bi bi-arrow-left me-1"></i>Back to Sign In
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
