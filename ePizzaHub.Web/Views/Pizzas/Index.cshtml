@model IEnumerable<ePizzaHub.Models.PizzaModel>

@{
    ViewData["Title"] = "Fresh Pizza Menu";
}

<div class="container py-5">
    <div class="row align-items-center mb-5 text-center text-md-start">
        <div class="col-md-6">
            <h1 class="display-4 fw-black text-dark mb-2">ePizza <span class="text-danger">Hub</span></h1>
            <p class="lead text-muted">Freshly baked software structures and cheese toppings delivered straight to your terminal.</p>
        </div>
        <div class="col-md-6 text-md-end">
            <a href="#" class="btn btn-outline-dark btn-lg rounded-pill px-4 shadow-sm position-relative">
                <i class="bi bi-cart3 me-2"></i> View Basket
            </a>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
        @foreach (var pizza in Model)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative tracking-card">
                    <div class="position-absolute top-0 end-0 m-3 z-3">
                        <span class="badge bg-danger fs-5 px-3 py-2 rounded-pill shadow-sm">$@pizza.f_price</span>
                    </div>

                    <div class="bg-light p-4 text-center">
                        <img src="@pizza.f_image_url" class="img-fluid rounded-3 object-fit-cover" style="height: 180px; width: 100%;" alt="@pizza.f_name">
                    </div>

                    <div class="card-body d-flex flex-column p-4">
                        <h4 class="card-title fw-bold text-dark mb-2">@pizza.f_name</h4>
                        <p class="card-text text-muted small flex-grow-1">@pizza.f_description</p>

                        <form asp-controller="Cart" asp-action="Add" method="post" class="mt-3">
                            <input type="hidden" name="pizzaUid" value="@pizza.f_uid" />
                            <div class="input-group mb-3 rounded-pill overflow-hidden bg-light border">
                                <span class="input-group-text bg-transparent border-0 text-muted ps-3">Qty</span>
                                <input type="number" name="quantity" class="form-control bg-transparent border-0 text-center fw-bold text-dark" value="1" min="1" max="10">
                            </div>
                            <button type="submit" class="btn btn-danger w-100 rounded-pill py-2.5 fw-bold shadow-sm">
                                <i class="bi bi-bag-plus-fill me-2"></i> Add to Order
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
