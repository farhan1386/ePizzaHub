@model IEnumerable<ePizzaHub.Models.CartItemModel>
@{
    ViewData["Title"] = "Your Basket Breakdown";
}

<div class="container py-5">
    <h1 class="display-6 fw-black text-dark mb-4"><i class="bi bi-cart4 text-danger me-2"></i>Review Your Order</h1>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 border rounded-4 bg-light">
            <i class="bi bi-basket3 text-muted display-1 mb-3 d-block"></i>
            <h4 class="fw-bold text-secondary">Your basket is completely empty</h4>
            <p class="text-muted mb-4">Looks like you haven't added any fresh pizza dough selections yet.</p>
            <a asp-controller="Pizzas" asp-action="Index" class="btn btn-danger rounded-pill px-4 py-2 fw-bold shadow-sm">Explore Our Menu</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-align-middle mb-0 text-center text-md-start">
                            <thead class="table-dark">
                                <tr>
                                    <th class="ps-4 text-start">Item Details</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th class="pe-4 text-end">Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody class="border-top-0">
                                @foreach (var item in Model)
                                {
                                    if (item.f_pizza != null)
                                    {
                                        <tr>
                                            <td class="ps-4 py-3 text-start">
                                                <div class="d-flex align-items-center gap-3">
                                                    <img src="@item.f_pizza.f_image_url" style="width: 50px; height: 50px; object-fit: cover;" class="rounded-3" alt="@item.f_pizza.f_name" onerror="this.src='https://placehold.co'">
                                                    <div>
                                                        <h6 class="fw-bold mb-0 text-dark">@item.f_pizza.f_name</h6>
                                                        <small class="text-muted font-monospace">Ref ID: @item.f_uid.ToString().Substring(0, 8)</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="py-3 align-middle">$@item.f_pizza.f_price</td>
                                            <td class="py-3 align-middle">
                                                <span class="badge bg-light text-dark border fs-6 px-3 py-2 rounded-pill">@item.f_quantity</span>
                                            </td>
                                            <td class="py-3 align-middle text-end fw-bold text-dark">$@(item.f_pizza.f_price * item.f_quantity)</td>
                                            <td class="pe-4 py-3 align-middle text-end">
                                                <!-- Trash Button Trigger to Remove Item -->
                                                <form asp-controller="CartItems" asp-action="Remove" asp-route-uid="@item.f_uid" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-link text-danger p-0 shadow-none"><i class="bi bi-trash3 fs-5"></i></button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Right Summary Widget Side Panel Block -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 bg-light">
                    <h5 class="fw-bold text-dark mb-3 border-bottom pb-2">Order Breakdown</h5>
                    <div class="d-flex justify-content-between mb-2 small text-muted">
                        <span>Items Subtotal</span>
                        <span>$@ViewBag.SubTotal?.ToString("F2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 small text-muted">
                        <span>Tax / Processing (5% VAT)</span>
                        <span>$@ViewBag.TaxAmount?.ToString("F2")</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between mb-4 fs-5 fw-black text-danger">
                        <span>Estimated Total</span>
                        <span>$@ViewBag.GrandTotal?.ToString("F2")</span>
                    </div>
                    <button class="btn btn-danger btn-lg w-100 rounded-pill fw-bold shadow py-3">
                        Proceed to Checkout <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </div>
            </div>
        </div>
    }
</div>
